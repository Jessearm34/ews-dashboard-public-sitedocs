{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "visualize_fasthtml/Dockerfile",
    "context": "."
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1,
    "healthcheckPath": "/login",
    "healthcheckTimeout": 120
  }
}
